  <script>
    const loginScreen = document.getElementById('loginScreen');
    const chatScreen = document.getElementById('chatScreen');
    const loginBtn = document.getElementById('loginBtn');
    const logoutBtn = document.getElementById('logoutBtn');
    const mobileLogoutBtn = document.getElementById('mobileLogoutBtn');
    const clearBtn = document.getElementById('clearBtn');
    const usernameInput = document.getElementById('usernameInput');
    const passwordInput = document.getElementById('passwordInput');
    const messages = document.getElementById('messages');
    const messageInput = document.getElementById('messageInput');
    const sendBtn = document.getElementById('sendBtn');
    const typing = document.getElementById('typing');
    const memberGreeting = document.getElementById('memberGreeting');

    let memberName = 'Kak';

    const faq = [
      {
        keys:['daftar','registrasi','buat akun','akun baru'],
        answer:'Untuk daftar akun baru, Kakak bisa klik menu Daftar, isi data yang diminta dengan benar, lalu pastikan nomor rekening/e-wallet sesuai nama akun. Setelah akun aktif, Kakak bisa login dan mulai cek menu deposit.'
      },
      {
        keys:['deposit','depo','isi saldo','top up'],
        answer:'Untuk deposit, silakan login akun, pilih menu Deposit, pilih metode pembayaran yang tersedia, lalu ikuti nominal dan tujuan pembayaran yang tampil. Setelah transfer berhasil, simpan bukti pembayaran jika sewaktu-waktu dibutuhkan untuk pengecekan.'
      },
      {
        keys:['withdraw','wd','tarik dana','penarikan'],
        answer:'Untuk withdraw, pastikan data rekening/e-wallet sudah sesuai dengan akun. Masuk ke menu Withdraw, isi nominal, lalu submit. Proses bisa berbeda tergantung antrean dan validasi sistem. Jika status terlalu lama pending, Kakak bisa hubungi admin resmi untuk pengecekan.'
      },
      {
        keys:['promo','bonus','rollingan','cashback','komisi'],
        answer:'Untuk promo dan bonus, Kakak bisa cek menu Promo karena syarat setiap bonus bisa berbeda, seperti minimal deposit, turnover, periode klaim, dan game yang berlaku. Baca syaratnya dulu ya supaya klaim bonus tidak gagal.'
      },
      {
        keys:['slot','rtp','provider','game slot'],
        answer:'Untuk slot, Kakak bisa pilih provider dan game sesuai preferensi. Perlu diingat, hasil permainan bersifat acak dan tidak ada pola yang bisa menjamin menang. Saran profesionalnya: pakai batas modal, jangan kejar kekalahan, dan main sesuai kemampuan.'
      },
      {
        keys:['casino','live casino','baccarat','roulette','blackjack'],
        answer:'Untuk casino/live casino seperti baccarat, roulette, atau blackjack, pastikan koneksi stabil dan pahami aturan meja sebelum bermain. Jika terjadi kendala bet, screenshot ID ronde dan detail transaksi agar admin bisa bantu cek lebih cepat.'
      },
      {
        keys:['bola','sportsbook','sportbook','parlay','mix parlay','taruhan bola'],
        answer:'Untuk sportsbook/bola, Kakak bisa pilih pertandingan, market, dan odds yang tersedia. Untuk parlay, beberapa pilihan digabung dalam satu tiket sehingga semua pilihan harus sesuai hasil agar tiket menang. Pastikan cek jam pertandingan dan odds sebelum submit.'
      },
      {
        keys:['lupa password','password','reset pass','tidak bisa login','gagal login'],
        answer:'Jika lupa password atau tidak bisa login, silakan gunakan fitur lupa password jika tersedia. Jika belum berhasil, hubungi admin resmi dengan menyertakan username dan data verifikasi yang diminta. Jangan bagikan password ke pihak lain ya, Kak.'
      },
      {
        keys:['maintenance','gangguan','error','pending','kendala'],
        answer:'Mohon maaf atas kendalanya, Kak. Untuk pengecekan lebih cepat, boleh info username, jenis kendala, waktu kejadian, nama game/provider, dan screenshot jika ada. Nanti admin bisa bantu cek sesuai data tersebut.'
      }
    ];

    const fallbackAnswers = [
      'Baik Kak, untuk pertanyaan tersebut aku bantu jelaskan secara umum ya. Kalau berkaitan dengan data akun, transaksi, atau kendala spesifik, sebaiknya Kakak siapkan username, jam kejadian, dan screenshot agar admin resmi bisa cek lebih akurat.',
      'Siap Kak. Secara umum kami bisa bantu info seputar akun, deposit, withdraw, promo, slot, casino, dan sportsbook. Untuk data sensitif seperti saldo, password, atau mutasi transaksi, mohon lanjutkan lewat admin resmi agar lebih aman.',
      'Baik Kak, aku bantu arahkan. Boleh jelaskan kendalanya lebih detail, misalnya menu yang dibuka, provider/game, nominal transaksi, atau pesan error yang muncul?'
    ];

    function sanitize(text){
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function addMessage(text,type='bot'){
      const row = document.createElement('div');
      row.className = `msg-row ${type}`;

      if(type === 'bot'){
        const avatar = document.createElement('div');
        avatar.className = 'avatar-sm';
        avatar.textContent = 'F';
        row.appendChild(avatar);
      }

      const bubble = document.createElement('div');
      bubble.className = `msg ${type}`;
      bubble.innerHTML = sanitize(text); 
